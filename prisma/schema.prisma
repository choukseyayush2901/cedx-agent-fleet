generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Record {
  id              String   @id
  owner           String
  deadline        String
  category        String
  notes           String
  amount          Float?
  version         Int

  sourceFormat    String

  status          String

  reasonCode      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditEvent {
  id         String   @id
  actor      String
  action     String
  recordId   String?
  createdAt  DateTime @default(now())
}